rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Rascunhos temporários: usuários podem criar, ler e apagar apenas seus próprios arquivos.
    match /temp/{userId}/{allPaths=**} {
      allow read, delete: if request.auth.uid == userId;
      allow create, update: if request.auth.uid == userId
                         && request.resource.size < 5 * 1024 * 1024 // 5MB limit
                         && request.resource.contentType.matches('image/.*|video/.*|audio/.*');
    }
    
    // Pasta final de produção: Subpastas explícitas para leitura pública.
    match /lovepages/{pageId}/gallery/{fileName} {
      allow read: if true;
      allow write: if false;
    }
    match /lovepages/{pageId}/timeline/{fileName} {
      allow read: if true;
      allow write: if false;
    }
     match /lovepages/{pageId}/puzzle/{fileName} {
      allow read: if true;
      allow write: if false;
    }
     match /lovepages/{pageId}/audio/{fileName} {
      allow read: if true;
      allow write: if false;
    }
    match /lovepages/{pageId}/memory-game/{fileName} {
      allow read: if true;
      allow write: if false;
    }
    match /lovepages/{pageId}/video/{fileName} {
      allow read: if true;
      allow write: if false;
    }
    
    // Regra legado (mantida por segurança, mas o ideal é não usar mais)
    match /gallery-images/{allPaths=**} { 
      allow read: if true; 
      allow write: if false; 
    }
  }
}
