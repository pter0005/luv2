
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Função para checar se o usuário é o dono do documento
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Coleção de Usuários
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      // Subcoleção de páginas dentro do usuário
      match /love_pages/{pageId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // Coleção PÚBLICA de páginas (Onde o link /p/ID busca os dados)
    match /lovepages/{pageId} {
      // QUALQUER PESSOA pode ler a página para ver a declaração
      allow read: if true;
      
      // APENAS o Admin (seu servidor) pode escrever aqui 
      // (O Admin SDK ignora as regras, então deixamos falso para o resto do mundo)
      allow write: if false;
    }
    
    // Coleção de Rascunhos (Payment Intents)
    match /payment_intents/{intentId} {
      // O usuário logado pode ler/escrever seu próprio rascunho
      // O servidor (Admin) também consegue acessar
      allow read, write: if request.auth != null;
    }

    match /templates/{templateId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
