# ─────────────────────────────────────────────────────────────
# Env vars NOVAS pro launch US (mycupid.net).
# Copia essas chaves pro .env.local / Netlify env settings.
# As chaves BR existentes (Mercado Pago, Meta PT, TikTok PT) permanecem.
# ─────────────────────────────────────────────────────────────

# ── Stripe (mandatório pro mercado US) ──────────────────────
# Pegue em: https://dashboard.stripe.com/apikeys (use live keys em prod)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Webhook signing secret — criado ao adicionar endpoint em dashboard.stripe.com/webhooks
#   Endpoint URL: https://mycupid.net/api/webhooks/stripe
#   Events: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Meta Pixel US (opcional — crie pixel separado em business.facebook.com) ──
# Se não criar, o pixel BR vai disparar em ambos domínios (prejudica relatórios)
NEXT_PUBLIC_META_PIXEL_ID_US=
META_ACCESS_TOKEN_US=

# ── TikTok Pixel US (opcional) ──
NEXT_PUBLIC_TIKTOK_PIXEL_ID_US=

# ── Resend (transactional email, opcional v1) ──
# https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM=receipts@mycupid.net

# ── Domínio canônico (não precisa mudar — código deriva do host) ──
# Mas pode override em dev com:
# NEXT_PUBLIC_FORCE_LOCALE=en
